    "1": {
      "name": "萌芽的一瞬",
      "desc": [
        "施放延奏技能盛放时，队伍中登场角色额外获得持续回复生命效果，每5秒回复维里奈20%攻击的生命值，持续30秒。"
      ]
    },
    "2": {
      "name": "抽叶的思考",
      "desc": [
        "施放共鸣技能扩繁试验时，额外获得1点【光合能量】和10点协奏能量。"
      ]
    },
    "3": {
      "name": "生长的选择",
      "desc": [
        "共鸣解放光合标记的治疗效果加成提升12%。"
      ]
    },
    "4": {
      "name": "盛放的拥抱",
      "desc": [
        "施放重击星星花绽放、空中攻击星星花绽放、共鸣解放草木生长或延奏技能盛放时，队伍中的角色衍射伤害加成提升15%，持续24秒。"
      ]
    },
    "5": {
      "name": "结果的奇迹",
      "desc": [
        "治疗生命值低于50%的角色时，维里奈的治疗效果加成提升20%。"
      ]
    },
    "6": {
      "name": "丰收的喜悦",
      "desc": [
        "重击星星花绽放及空中攻击星星花绽放的伤害提升20%，命中目标时触发1次协同攻击，并为附近队伍中所有角色回复生命值，此次协同攻击伤害和回复生命值等同于共鸣解放光合标记。"
      ]
    }
  },
  "passive": [
    {
      "name": "生命的恩惠",
      "desc": [
