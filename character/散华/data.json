    "1": {
      "name": "孤身孑然",
      "desc": [
        "施放第5段普攻时，散华自身暴击提升15%，持续10秒。"
      ]
    },
    "2": {
      "name": "净雪明心",
      "desc": [
        "重击爆裂消耗的耐力降低10点，施放共鸣技能朔雪永冻时散华抗打断能力提升，持续5秒。"
      ]
    },
    "3": {
      "name": "目视异常",
      "desc": [
        "散华攻击生命低于70%的目标时，造成的伤害提升35%。"
      ]
    },
    "4": {
      "name": "剑修五蕴",
      "desc": [
        "施放共鸣解放焦瞑冻土时，回复10点共鸣能量。",
        "并且5秒内的下次重击爆裂伤害提升120%。"
      ]
    },
    "5": {
      "name": "颠覆无常",
      "desc": [
        "共鸣回路冰绽的暴击伤害提升100%。",
        "即使没有成功引爆，【冰棘】、【冰棱】、【冰川】也会在消失时直接爆炸。"
      ]
    },
    "6": {
      "name": "曙色天光",
      "desc": [
        "引爆【冰棱】或【冰川】后，队伍中的角色攻击提升10%，持续20秒，可叠加2层。"
      ]
    }
  },
