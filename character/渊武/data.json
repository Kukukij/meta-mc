  "cons": {
    "1": {
      "name": "点一盏清茗",
      "desc": [
        "渊武处在共鸣回路雷厉风行状态时，自身的普攻攻速提升20%，重击攻速提升20%。"
      ]
    },
    "2": {
      "name": "敛狂戾之心",
      "desc": [
        "施放变奏技能轰雷时，渊武额外回复15点共鸣能量。"
      ]
    },
    "3": {
      "name": "正周身之气",
      "desc": [
        "共鸣技能雷之楔的协同攻击命中目标时，基于渊武20%防御额外提升伤害。"
      ]
    },
    "4": {
      "name": "挥刚猛之拳",
      "desc": [
        "施放共鸣解放寂土重明时，队伍中在场角色获得渊武自身200%防御的护盾，持续10秒。"
      ]
    },
    "5": {
      "name": "顾一方天地",
      "desc": [
        "共鸣技能雷之楔在场时，渊武的共鸣解放伤害加成提升50%。"
      ]
    },
    "6": {
      "name": "保八方平安",
      "desc": [
        "处在共鸣技能雷之楔范围内的附近队伍中所有角色将持续获得效果：防御提升32%，该效果持续时间3秒。"
      ]
    }
  },
  "passive": [
    {
      "name": "决电",
      "desc": [
        "共鸣技能掀雷的伤害倍率获得提升40%，并且削减怪物共振度的能力提升。"
      ]
    },
    {
      "name": "敛光",
      "desc": [
        "共鸣技能雷池及共鸣技能掀雷的范围大幅扩大，战斗状态中离场时，若【锋芒】没有充满，渊武会自动在原地留下1个共鸣技能雷之楔。"
      ]
    }
  ],
