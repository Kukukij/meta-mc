    "1": {
      "name": "隐我所思",
      "desc": [
        "施放共鸣技能赫羽三相或重击焚身以火时，长离的抗打断能力提升，且造成的伤害提升10%。"
      ]
    },
    "2": {
      "name": "循我所望",
      "desc": [
        "获得【离火】时，长离的暴击提升25%，持续8秒。"
      ]
    },
    "3": {
      "name": "据我所闻",
      "desc": [
        "共鸣解放离火照丹心造成的伤害提升80%。"
      ]
    },
    "4": {
      "name": "饰我所言",
      "desc": [
