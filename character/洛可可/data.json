  "cons": {
    "1": {
      "name": "沉闷的灰暗涌进船舱",
      "desc": [
        "施放共鸣技能高难度设计时，额外回复100点【想象力】与10点协奏能量。",
        "普攻幻想照进现实免疫打断。"
      ]
    },
    "2": {
      "name": "海萤石闪烁着微弱光芒",
      "desc": [
        "施放普攻幻想照进现实时，队伍中的角色湮灭伤害加成提升10%，可叠加3层，持续30秒。满层时，队伍中的角色湮灭伤害加成额外提升10%，持续30秒。"
      ]
    },
    "3": {
      "name": "用心观察，以手丈量",
      "desc": [
        "施放变奏技能佩洛，来帮忙时，洛可可暴击提升10%，暴击伤害提升30%，持续15秒。"
      ]
    },
    "4": {
      "name": "千万“奇藏”于箱中汇聚",
      "desc": [
        "施放共鸣技能高难度设计时，普攻幻想照进现实伤害倍率提升60%，持续12秒。"
      ]
    },
    "5": {
      "name": "重建乐土，在舞台上",
      "desc": [
        "共鸣解放即兴喜剧，开场伤害倍率提升20%，重击伤害倍率提升80%。"
      ]
    },
    "6": {
      "name": "飞吧，乘着金色的翅膀",
      "desc": [
        "施放共鸣解放即兴喜剧，开场时，获得如下效果，12秒内：",
        "·普攻幻想照进现实攻击目标时，无视对方60%的防御。",
        "·普攻幻想照进现实第3段落地后，会将洛可可送上空中，进入飞跃幻想状态，此时短按普攻，将会施放普攻构筑现实，普攻构筑现实免疫打断，造成普攻幻想照进现实第3段100%的伤害，此次伤害为重击伤害。",
        "·普攻构筑现实落地后，会将洛可可送上空中，进入飞跃幻想状态。普攻构筑现实需要在处于飞跃幻想状态时才可施放。"
      ]
    }
  },
  "passive": [
    {
      "name": "沉浸式演出",
      "desc": [
        "施放共鸣技能或重击时，洛可可攻击提升20%，持续12秒。"
      ]
    },
    {
      "name": "无尽引力珍奇箱",
      "desc": [
        "施放延奏技能后，下一个登场角色的探索工具，替换为【珍奇箱】。",
        "【珍奇箱】",
        "·使用后以【珍奇箱】为中心牵引周围目标，造成共计100点的湮灭伤害，此次伤害为探索工具伤害。该技能施放时，视为施放声骸技能。",
        "·【珍奇箱】持续14秒，若切换至其他角色则【珍奇箱】提前消失。"
      ]
    }
  ],
