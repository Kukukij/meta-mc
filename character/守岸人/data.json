    "1": {
      "name": "不语者假想",
      "desc": [
        "共鸣解放终末回环展开的星域获得加强：",
        "·治疗和增益效果生效范围增加150%。",
        "·持续时间增加10秒。",
        "·施放变奏技能洞悉后不再结束星域。"
      ]
    },
    "2": {
      "name": "夜幕的赠予与拒绝",
      "desc": [
        "浅析星域新增额外效果：附近队伍中的角色攻击提升40%。"
      ]
    },
    "3": {
      "name": "无限正将我等待",
      "desc": [
        "施放共鸣解放终末回环时，守岸人额外回复20点协奏能量，每25秒可触发1次。"
      ]
    },
    "4": {
      "name": "万物寂静满溢",
      "desc": [
        "施放共鸣技能混沌理论时，治疗效果加成提升70%。"
      ]
    },
    "5": {
      "name": "来自缄默的回声",
      "desc": [
        "普攻第三段牵引范围增加50%，共鸣回路演绎牵引范围增加30%。"
      ]
    },
    "6": {
      "name": "我所驶向的新世界",
      "desc": [
        "变奏技能洞悉伤害倍率提升42%。施放变奏技能洞悉时，守岸人的暴击伤害提升500%。"
      ]
    }
  },
  "passive": [
    {
      "name": "死生流溢",
      "desc": [
        "队伍中有守岸人自身以外的角色受到致死伤害时，此次伤害不会使该角色倒下并获得守岸人当前50%生命值，守岸人扣除等量生命值。守岸人最少保留1点生命值，该效果每10分钟可触发1次。"
      ]
    },
    {
      "name": "自我引力",
      "desc": [
        "队伍中登场角色处于星域生效范围内时，守岸人共鸣效率提升10%，若漂泊者处于同一编队中，漂泊者共鸣效率提升10%。"
      ]
    }
  ],
