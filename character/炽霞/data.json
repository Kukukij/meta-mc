    "1": {
      "name": "剧院的英雄戏",
      "desc": [
        "施放共鸣技能轰轰时，必定暴击。"
      ]
    },
    "2": {
      "name": "跃动的火星",
      "desc": [
        "施放共鸣解放炽烈焰火期间，每击败1个目标，回复5点共鸣能量，每次最多可回复20点。"
      ]
    },
    "3": {
      "name": "不灭的火把",
      "desc": [
        "共鸣解放炽烈焰火对生命值低于50%的目标，伤害提升40%。"
      ]
    },
    "4": {
      "name": "英雄的绝招",
      "desc": [
        "施放共鸣解放炽烈焰火时，炽霞获得60发【热压弹】，并立即重置一次共鸣技能咻咻斗意的冷却时间。"
      ]
    },
    "5": {
      "name": "胜利的枪弹焰火",
      "desc": [
        "固有技能加麻加辣叠加至满层时，攻击额外提升30%。"
      ]
    },
    "6": {
      "name": "剧终的回归彩蛋",
      "desc": [
        "触发共鸣技能轰轰后，队伍中的角色普攻伤害加成提升25%，持续15秒。"
      ]
    }
  },
  "passive": [
    {
      "name": "灼热弹匣",
      "desc": [
