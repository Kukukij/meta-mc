  "cons": {
    "1": {
      "name": "如剑不动，相由心生",
      "desc": [
        "施放答剑·质黑相青时，仇远获得免疫打断的效果。",
        "仇远暴击率提升15%。"
      ]
    },
    "2": {
      "name": "剑啊，谓我弃绝弦歌不辍",
      "desc": [
        "【竹照】获得时增加额外效果：附近队伍中的角色声骸技能伤害加深30%。"
      ]
    },
    "3": {
      "name": "剑啊，谓我弃绝割股之心",
      "desc": [
        "仇远攻击力提升20%。",
        "施放共鸣技能后，若协奏能量已满，则可再次短按共鸣技能施放剑雨如注技能。",
        "施放剑雨如注时，消耗全部协奏能量，回复【挑灯问剑】400点，并造成仇远自身800%攻击的气动伤害，此次伤害视为声骸技能伤害，下次普攻衔接答剑·质黑相青第三段，此技能每30秒可施放1次。",
        "施放剑雨如注后，下次仇远进入【淋漓醉墨】状态时无法获得且从容效果，下次【淋漓醉墨】状态下答剑·弦歌不缀、答剑·割股之心、答剑·忠烈死节伤害倍率增加400%。"
      ]
    },
    "4": {
      "name": "剑啊，谓我弃绝忠烈死节",
      "desc": [
        "万钧一断伤害倍率增加600%。"
      ]
    },
    "5": {
      "name": "剑啊，如今我弹铗而歌",
      "desc": [
        "仇远获得20%无视怪物防御。"
      ]
    },
    "6": {
      "name": "如是我闻、我见、我言",
      "desc": [
        "仇远退出【淋漓醉墨】状态时，对范围内敌人造成自身500%攻击的气动伤害，该伤害视为声骸技能伤害。",
        "队伍中角色造成的声骸技能伤害无视敌人10%全属性抗性。"
      ]
    }
  },
  "passive": [
    {
      "name": "且从容",
      "desc": [
        "进入【淋漓醉墨】状态时，仇远获得且从容效果，持续10秒。",
        "施放答剑·弦歌不缀、答剑·割股之心、答剑·忠烈死节时伤害加深50%，并在命中目标时额外回复10点协奏能量，该效果每15秒可触发1次。",
        "·切换至其他角色时，效果提前结束。"
      ]
    },
    {
      "name": "与尔同销万古愁",
      "desc": [
        "仇远施放声骸技能时，仇远的竹壶会吸收溢散的能量转化为【金药玉馔】。",
        "下次获得【挑灯问剑】时，消耗【金药玉馔】获得10%攻击力，持续20秒。"
      ]
    }
  ],
